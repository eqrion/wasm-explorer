{
  "type": "module",
  "scripts": {
    "build": "npm run build-component && npm run transpile && npm run typecheck && npm run build-js && npm run build-css && npm run copy-files",
    "build-component": "cd crates/component && cargo component build --release --target wasm32-wasip1",
    "build-js": "for source in Worker.ts App.tsx; do esbuild --bundle --format=esm src/$source --outdir=dist; done",
    "build-css": "npx @tailwindcss/cli -i ./pages/style.css -o ./dist/style.css",
    "copy-files": "cp pages/index.html pages/favicon.png pages/logo.svg component-built/*.wasm dist",
    "clean": "rm -rf crates/component/src/bindings.rs component-built dist && echo '## you will need to run `cargo clean` separately to delete cargo artifacts'",
    "transpile": "jco transpile --no-nodejs-compat ./crates/component/target/wasm32-wasip1/release/component.wasm --out-dir component-built",
    "typecheck": "tsc --jsx react",
    "watch": "nodemon --watch 'pages/**/*' --watch 'src/**/*' --watch 'crates/**/*' --ext 'html,css,ts,tsx,rs' --exec 'npm run build'",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'pages/**/*.{html,css}' && cargo fmt --manifest-path crates/component/Cargo.toml",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test": "npm run test:unit && npm run test:e2e",
    "build-extension": "cd vscode-extension && node build.mjs",
    "package-extension": "cd vscode-extension && npx @vscode/vsce package"
  },
  "dependencies": {
    "@bytecodealliance/jco": "^1.2.4",
    "@tailwindcss/cli": "^4.1.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitest/coverage-v8": "^2.1.0",
    "esbuild": "0.25.5",
    "jsdom": "^25.0.0",
    "nodemon": "3.1.10",
    "prettier": "3.6.2",
    "serve": "^14.2.3",
    "vitest": "^2.1.0"
  }
}
