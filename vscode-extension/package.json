{
  "name": "wasm-explorer",
  "displayName": "WASM Explorer",
  "description": "View .wasm binary files as syntax-highlighted WAT text",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "wasmExplorer.watView",
        "displayName": "WASM Explorer",
        "selector": [{ "filenamePattern": "*.wasm" }],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "esbuild": "0.25.5",
    "typescript": "^5.4.5"
  }
}
